# ──────────────────────────────────────────────────────────────────────
#  Discord AI Bot — Local Inference Configuration
# ──────────────────────────────────────────────────────────────────────
#  Copy this file to .env and edit the values marked EDIT.

# ════════════════════════════════════
#  REQUIRED
# ════════════════════════════════════

# Discord bot token — create at developer.discord.com (Bot → Reset Token)
DISCORD_BOT_TOKEN=your-discord-bot-token-here   # EDIT

# OpenWebUI API key — Settings → Keys in the OWUI web UI
OPENWEBUI_API_KEY=owui-api-key-goes-here        # EDIT

# ════════════════════════════════════
#  BACKEND (OpenWebUI gateway)
# ════════════════════════════════════

# OpenWebUI API URL.
#   Local / docker:     http://localhost:3000/api/v1
#   Inside Docker:      http://open-webui:8080/api/v1  ← use the service name
OPENAI_API_URL=http://localhost:3000/api/v1       # EDIT if needed

# Default model loaded in OpenWebUI (must exactly match what's running)
MODEL_NAME=default-model-name                     # EDIT — e.g. qwen3.6:latest

# ════════════════════════════════════
#  BOT BEHAVIOUR
# ════════════════════════════════════

# System prompt injected into every chat context (can also be overridden per-character in characters.json)
SYSTEM_PROMPT=You are a helpful AI assistant embedded in a Discord bot.

# Messages retained per channel (rounds = user+AI pairs). 0 = unlimited.
CONTEXT_WINDOW=10                                 # optional

# Set to "clear" once and restart the bot — wipes all stored chat history, then revert to empty after first run.
CHAT_HISTORY_RESET=                               # set to "clear" once to reset history

# Prefix for non-slash commands (e.g. !ai what is ai?)
BOT_PREFIX=!ai                                    # optional

# ── HTTP timeouts ─────────────────

# Seconds to wait for a model response before giving up
AI_REQUEST_TIMEOUT=120                            # optional; increase if your GPU is slow

# ════════════════════════════════════
#  KNOWLEDGE / RAG (filesystem-based)
# ════════════════════════════════════

# Name of the OpenWebUI knowledge base to query for /ai commands
KB_KNOWLEDGE_BASE=HumbleWood                      # EDIT — must match a KB in OWUI

# On the bot side: mount path where KB chunk files are shared.
# Inside Docker this should be the volume mount point (same as docker-compose-example.yml).
KB_SHARED_DIR=/shared-knowledge/kb/uploads        # rarely needs editing

