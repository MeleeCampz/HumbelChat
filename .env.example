# ──────────────────────────────────────────────────────────────────────
#  Discord AI Bot — Configuration (provider-agnostic)
# ──────────────────────────────────────────────────────────────────────
#  Copy this file to .env and edit the values marked EDIT.

# ════════════════════════════════════
#  REQUIRED
# ════════════════════════════════════

# Discord bot token — create at https://discord.com/developers/applications (Bot → Reset Token)
DISCORD_BOT_TOKEN=your-discord-bot-token-here   # EDIT

# ════════════════════════════════════
#  AI PROVIDER (any OpenAI-compatible API)
# ════════════════════════════════════

# Base URL for the inference provider.
#   Direct Ollama            → http://host.docker.internal:11434/v1
#   Ollama on remote host    → http://<IP>:11434/v1
#   Cloud (e.g. OpenRouter)  → https://openrouter.ai/api/v1
INFER_URL=http://192.168.178.96:11434/v1       # EDIT

# API key — leave empty for local Ollama; set for cloud providers
INFER_API_KEY=                                  # EDIT

# ════════════════════════════════════
#  BOT BEHAVIOUR
# ════════════════════════════════════

# Messages retained per channel (pairs = user+AI turns).
CONTEXT_WINDOW=10                               # optional; increase if your GPU is slow

# Set to "clear" once and restart the bot — wipes all stored chat history.
CHAT_HISTORY_RESET=                              # set to "clear" once then remove

# Prefix for non-slash commands (e.g. !ai what is ai?)
BOT_PREFIX=!ai                                  # optional

# HTTP timeout in seconds before giving up on a model response
AI_REQUEST_TIMEOUT=120                           # optional; increase if your GPU is slow

# ════════════════════════════════════
#  KNOWLEDGE BASE (filesystem)
# ════════════════════════════════════

# Default KB name to query on startup.
# Must match a folder under KB_PATH when running standalone, or the Docker volume mount point.
KB_DEFAULT_KB=humblewood                        # EDIT — lowercase slug

# Where KB source files live (only used for /upload_kb and /list_kb_docs).
# When running with the shared OWUI volume this will be the Docker path;
# otherwise set it to a local directory like "./data/knowledge".
KB_PATH=/shared-knowledge/kb/uploads            # EDIT if not using the shared volume

# Chunk size (default tokens per KB chunk) for auto-indexing.
CHUNK_SIZE=2000                                 # optional; change then re-run /reindex_kb
