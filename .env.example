# ──────────────────────────────────────────────────────────────────────
#  Discord AI Bot — Local Inference Configuration
# ──────────────────────────────────────────────────────────────────────
#  Copy this file to .env and edit the values.

# --- Discord (required) ---
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# --- OpenWebUI Authentication ---
# Generate an API key in your OpenWebUI:  Settings → Keys → Create Key
OPENWEBUI_API_KEY=<paste-your-key-here>

# --- Local AI Backend ---
# OpenWebUI API prefix is /api/v1 (not just /v1)
OPENAI_API_URL=http://192.168.X.X:3000/api/v1

# --- Model Selection ---
MODEL_NAME=qwen2.5                    # must match a loaded model in OpenWebUI

# --- Bot Behaviour (optional) ---
SYSTEM_PROMPT=You are a helpful AI assistant embedded in a Discord bot.
BOT_PREFIX=!ai
CONTEXT_WINDOW=10
